# .env.example — Phase 2 required variables (names only; never commit real values)
# Copy to .env.local and fill in. Mirror the same keys into Vercel → Settings → Environment Variables for prod.

# ── Neon Postgres (Slice 1) ───────────────────────────────────────────────
# From the Neon dashboard → your project → Connection Details. Pick the branch per env.
# Pooled connection (app runtime). This points at your DEV branch locally.
DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/dbname?sslmode=require"
# Direct/unpooled connection (migrations). Same DEV branch, non-pooler host.
DATABASE_URL_UNPOOLED="postgresql://user:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require"
# TEST branch connection (unit/integration tests run + reset against this — never prod).
TEST_DATABASE_URL="postgresql://user:password@ep-yyyy-pooler.region.aws.neon.tech/dbname?sslmode=require"
# PROD `main` branch — DEPLOY-TIME ONLY. Consumed BY NAME (never hand-pasted) by
# `db:migrate:main` (uses _UNPOOLED), `db:seed:main`, and `verify-preview-shape.mjs main`.
# Get these from the Neon `main` branch or Vercel Production; NOT the dev strings above.
DATABASE_URL_MAIN_UNPOOLED="postgresql://user:password@ep-zzzz.region.aws.neon.tech/dbname?sslmode=require"
DATABASE_URL_MAIN="postgresql://user:password@ep-zzzz-pooler.region.aws.neon.tech/dbname?sslmode=require"

# ── Auth.js v5 (Slice 3) ──────────────────────────────────────────────────
# Generate: `npx auth secret`  (or `openssl rand -base64 32`)
AUTH_SECRET="replace-with-generated-secret"
# GitHub OAuth App → Client ID / Client Secret
AUTH_GITHUB_ID="replace-with-github-oauth-client-id"
AUTH_GITHUB_SECRET="replace-with-github-oauth-client-secret"
# Comma-separated admin allowlist checked by isAdmin(). Only these identities get admin.
ADMIN_EMAILS="you@example.com"
# Optional locally (Auth.js auto-detects on Vercel). Set for prod if needed.
# AUTH_URL="https://your-portfolio.vercel.app"

# ── GitHub ingestion API (Slice 4) ────────────────────────────────────────
# Read-only PAT (public repo scope). Optional but recommended: lifts the GitHub API
# rate limit from 60/hr (unauthenticated) to 5000/hr.
GITHUB_TOKEN="replace-with-readonly-pat"

# ── Upstash Redis — rate limiting (Slice 5) ───────────────────────────────
# Upstash console → create Redis DB → REST API section.
UPSTASH_REDIS_REST_URL="https://xxxx.upstash.io"
UPSTASH_REDIS_REST_TOKEN="replace-with-upstash-rest-token"

# ── Resend — visitor card email (Slice 6) ─────────────────────────────────
# Resend console → API Keys. Free tier + unverified domain: emails must be sent
# from onboarding@resend.dev and only deliver to your Resend account address.
RESEND_API_KEY="re_replace-with-resend-api-key"
# Where visitor-card submissions are emailed (the site owner's inbox).
CONTACT_EMAIL="you@example.com"
