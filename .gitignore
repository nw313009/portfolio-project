# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# playwright
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/
/.playwright-mcp/

# velite generated content
/.velite/
/public/static/
/test/fixtures/velite-invalid-content/.velite/
/test/fixtures/velite-invalid-content/static/
/test/fixtures/velite-invalid-content/node_modules/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# ...except the names-only example contract: it MUST be tracked so a fresh clone
# knows which env vars exist. Real values never live here (see the header).
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

#.env
.env.local
.env*.local