{
  "name": "projects-homepage",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "prebuild": "velite --clean",
    "build": "next build",
    "start": "next start",
    "postinstall": "node scripts/ensure-playwright-browsers.mjs",
    "lint": "eslint",
    "corpus:check": "node scripts/corpus-check.mjs",
    "pretypecheck": "velite",
    "typecheck": "tsc --noEmit",
    "pretest": "velite",
    "test": "vitest run",
    "test:e2e": "node scripts/run-e2e.mjs",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate:test": "node scripts/db-migrate-test.mjs",
    "db:migrate:main": "node scripts/db-migrate-main.mjs",
    "db:seed:test": "node scripts/seed-test.mjs",
    "db:seed:main": "node scripts/seed-main.mjs",
    "predb:seed": "velite",
    "db:seed": "tsx scripts/seed-projects.ts"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.24.0",
    "motion": "^12.42.2",
    "next": "15.5.20",
    "next-auth": "5.0.0-beta.31",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.6.2",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "resend": "^6.17.2",
    "shadcn": "^4.13.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.3",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "15.5.20",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4",
    "tsx": "^4.23.1",
    "typescript": "^5",
    "velite": "^0.4.0",
    "vitest": "^4.1.10"
  }
